{
  "name": "qortal-hub",
  "version": "1.0.0",
  "description": "A desktop app that gives you access to the Qortal network",
  "author": {
    "name": "",
    "email": "qortalblockchain@gmail.com"
  },
  "homepage": "https://qortal.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qortal/Qortal-Hub.git"
  },
  "build": {
    "appId": "org.Qortal.Qortal-Hub",
    "publish": [
      {
        "provider": "github",
        "owner": "Qortal",
        "repo": "Qortal-Hub"
      }
    ]
  },
  "license": "GPL-3.0",
  "main": "build/src/index.js",
  "scripts": {
    "build": "tsc && electron-rebuild",
    "electron:start-live": "node ./live-runner.js",
    "electron:start": "npm run build && electron --inspect=5858 ./",
    "electron:pack": "node ./scripts/run-electron-package.mjs pack",
    "electron:make": "node ./scripts/run-electron-package.mjs local",
    "electron:make-local": "node ./scripts/run-electron-package.mjs local",
    "electron:make-lin": "node ./scripts/run-electron-package.mjs lin",
    "electron:make-mac": "node ./scripts/run-electron-package.mjs mac",
    "electron:make-win": "node ./scripts/run-electron-package.mjs win",
    "electron:make-arm": "node ./scripts/run-electron-package.mjs arm",
    "electron:make-lin-docker": "bash ./scripts/run-linux-build-in-docker.sh",
    "electron:make-all": "node ./scripts/run-electron-package.mjs all",
    "bundle:reticulum": "node ./scripts/run-build-rnsd-frozen.mjs",
    "bundle:reticulum-venv": "node ./scripts/bundle-reticulum-runtime.mjs",
    "generate:mesh-network-identity": "python3 -c \"import RNS; RNS.Identity().to_file('resources/mesh-network.identity')\""
  },
  "dependencies": {
    "@capacitor-community/electron": "^5.0.0",
    "@silentbot1/nat-api": "^0.4.9",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.3",
    "electron-is-dev": "~2.0.0",
    "electron-serve": "~1.1.0",
    "electron-unhandled": "~4.0.1",
    "electron-updater": "^6.6.2",
    "electron-window-state": "^5.0.3",
    "extract-zip": "^2.0.1",
    "selfsigned": "^5.5.0",
    "tweetnacl": "^1.0.3",
    "write-file-atomic": "^7.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/write-file-atomic": "^4.0.3",
    "electron": "^32.3.1",
    "electron-builder": "^25.1.8",
    "shelljs": "^0.8.5",
    "typescript": "^5.0.4"
  },
  "overrides": {
    "form-data": "^4.0.4"
  },
  "keywords": [
    "capacitor",
    "electron"
  ]
}
